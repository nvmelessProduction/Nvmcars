# =============================================================
# Nvmcars — environment variables
# Copy this file to ".env" (already gitignored) and fill in your keys.
# Only EXPO_PUBLIC_* vars are exposed to the app; others stay server-side.
# =============================================================

# Supabase (from supabase.com -> Project Settings -> API)
EXPO_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PLACEHOLDER

# Stripe publishable key (from dashboard.stripe.com -> Developers -> API keys)
# Used by the Stripe RN SDK on the app side. Secret key stays in Edge Functions.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER

# Optional: app environment label
EXPO_PUBLIC_ENV=development
